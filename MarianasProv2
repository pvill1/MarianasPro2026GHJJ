<title>Marianas Pro Manila 2026 · Kamphuis Fabricio</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0c10; --surface: #12151b; --surface2: #1a1e27;
  --border: rgba(255,255,255,0.07); --border2: rgba(255,255,255,0.13);
  --text: #f0f2f7; --muted: #6b7280; --accent: #e8ff47;
  --blue: #4fa3ff; --blue-dim: rgba(79,163,255,0.12);
  --red: #ff6b6b; --green: #4ade80; --orange: #fb923c; --purple: #c084fc;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; overflow-x: hidden; }
body::before { content: ''; position: fixed; inset: 0; background: radial-gradient(ellipse 60% 40% at 80% 10%, rgba(232,255,71,0.04) 0%, transparent 60%), radial-gradient(ellipse 50% 60% at 10% 80%, rgba(79,163,255,0.04) 0%, transparent 60%); pointer-events: none; z-index: 0; }
.page { position: relative; z-index: 1; max-width: 480px; margin: 0 auto; padding: 0 16px 60px; }
header { padding: 32px 0 24px; border-bottom: 1px solid var(--border); margin-bottom: 20px; }
.header-top { display: flex; align-items: flex-start; justify-content: space-between; }
.event-name { font-family: 'Bebas Neue', sans-serif; font-size: 46px; line-height: 0.92; letter-spacing: 1px; color: var(--text); }
.event-name span { color: var(--accent); }
.event-date { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); text-align: right; line-height: 1.6; margin-top: 4px; }
.team-badge { display: inline-flex; align-items: center; gap: 6px; margin-top: 12px; background: var(--surface2); border: 1px solid var(--border2); padding: 5px 12px; border-radius: 999px; font-size: 12px; font-weight: 500; color: var(--muted); }
.team-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
.sync-row { display: flex; align-items: center; gap: 6px; margin-top: 8px; font-size: 11px; color: var(--muted); }
.sync-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--muted); flex-shrink: 0; transition: background 0.3s; }
.sync-dot.live { background: var(--green); }
.next-wrap { margin-bottom: 20px; }
.next-card { background: linear-gradient(135deg, #1a2010 0%, #141a0d 100%); border: 1px solid rgba(232,255,71,0.2); border-radius: 16px; padding: 18px 20px; position: relative; overflow: hidden; }
.next-card::before { content: ''; position: absolute; top: -30px; right: -30px; width: 120px; height: 120px; background: radial-gradient(circle, rgba(232,255,71,0.12), transparent 70%); pointer-events: none; }
.next-eyebrow { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.12em; color: var(--accent); text-transform: uppercase; margin-bottom: 6px; }
.next-name { font-size: 22px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
.next-sub { font-size: 12px; color: rgba(232,255,71,0.5); margin-bottom: 14px; }
.countdown-row { display: flex; gap: 8px; }
.cd-unit { background: rgba(0,0,0,0.3); border: 1px solid rgba(232,255,71,0.15); border-radius: 10px; padding: 8px 12px; text-align: center; min-width: 54px; }
.cd-num { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--accent); line-height: 1; }
.cd-label { font-size: 9px; color: rgba(232,255,71,0.4); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 1px; }
.all-done { font-size: 16px; font-weight: 500; color: var(--accent); padding: 4px 0; }
.ready-banner { display: none; align-items: center; gap: 8px; background: rgba(232,255,71,0.1); border: 1px solid rgba(232,255,71,0.3); border-radius: 10px; padding: 10px 14px; margin-top: 12px; font-size: 13px; font-weight: 500; color: var(--accent); }
.ready-banner.show { display: flex; }
.pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); animation: pulse 1.2s ease-in-out infinite; flex-shrink: 0; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.7)} }
.filters { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 18px; }
.pill { font-size: 12px; font-weight: 500; padding: 6px 14px; border-radius: 999px; border: 1px solid var(--border2); background: var(--surface); color: var(--muted); cursor: pointer; -webkit-tap-highlight-color: transparent; }
.pill.active { background: var(--accent); color: #0a0c10; border-color: var(--accent); font-weight: 600; }
.card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 16px 18px; margin-bottom: 10px; transition: border-color 0.2s, opacity 0.3s; }
.card.is-next { border-color: rgba(232,255,71,0.35); background: #13160e; }
.card.is-past { opacity: 0.4; }
.card.has-win { opacity: 1; border-color: rgba(74,222,128,0.35); }
.card.has-lose { opacity: 1; border-color: rgba(255,107,107,0.3); }
.card.locked { opacity: 0.3; border-style: dashed; }
.card.cancelled { opacity: 0.2; border-style: dashed; border-color: rgba(255,107,107,0.25); }
.card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
.fighter-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.belt-pip { width: 10px; height: 10px; border-radius: 50%; border: 1.5px solid rgba(255,255,255,0.15); flex-shrink: 0; }
.fighter-name { font-size: 17px; font-weight: 600; color: var(--text); }
.next-badge { font-size: 9px; font-weight: 600; background: var(--accent); color: #0a0c10; padding: 2px 7px; border-radius: 999px; letter-spacing: 0.05em; }
.locked-badge { font-size: 9px; font-weight: 600; background: rgba(255,255,255,0.06); color: var(--muted); padding: 2px 7px; border-radius: 999px; }
.cancelled-badge { font-size: 9px; font-weight: 600; background: rgba(255,107,107,0.12); color: var(--red); padding: 2px 7px; border-radius: 999px; }
.time-col { text-align: right; flex-shrink: 0; margin-left: 8px; }
.start-time { font-family: 'Bebas Neue', sans-serif; font-size: 22px; color: var(--blue); line-height: 1; }
.start-time.past { color: var(--muted); }
.match-cd { font-size: 10px; color: var(--muted); font-family: 'DM Mono', monospace; margin-top: 2px; }
.match-cd.soon { color: var(--accent); }
.ready-row { display: flex; align-items: center; gap: 6px; background: rgba(232,255,71,0.08); border: 1px solid rgba(232,255,71,0.18); border-radius: 7px; padding: 6px 10px; margin-bottom: 10px; font-size: 12px; font-weight: 500; color: var(--accent); }
.tags { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 10px; }
.tag { font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 5px; letter-spacing: 0.04em; text-transform: uppercase; }
.tag-gi { background: rgba(74,222,128,0.1); color: var(--green); }
.tag-nogi { background: rgba(251,146,60,0.12); color: var(--orange); }
.tag-final { background: rgba(255,107,107,0.12); color: var(--red); }
.tag-semi { background: rgba(192,132,252,0.12); color: var(--purple); }
.tag-quarter { background: rgba(79,163,255,0.12); color: var(--blue); }
.tag-cond { background: rgba(255,255,255,0.05); color: var(--muted); }
.meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 12px; margin-bottom: 10px; }
.meta-item { font-size: 11px; color: var(--muted); }
.meta-item strong { color: rgba(240,242,247,0.85); font-weight: 500; }
.divider { height: 1px; background: var(--border); margin-bottom: 10px; }
.vs-row { font-size: 12px; color: var(--muted); }
.vs-row strong { color: var(--text); font-weight: 500; }
.opp-label { font-size: 11px; color: var(--muted); margin-bottom: 7px; }
.opp-btns { display: flex; gap: 6px; flex-wrap: wrap; }
.opp-btn { flex: 1; min-width: 120px; background: var(--surface2); border: 1px solid var(--border2); border-radius: 10px; padding: 8px 12px; cursor: pointer; text-align: left; -webkit-tap-highlight-color: transparent; }
.opp-btn.selected { background: var(--blue-dim); border-color: rgba(79,163,255,0.4); }
.opp-btn-name { font-size: 12px; font-weight: 500; color: var(--text); margin-bottom: 2px; }
.opp-btn.selected .opp-btn-name { color: var(--blue); }
.opp-btn-team { font-size: 10px; color: var(--muted); }
.opp-result { margin-top: 8px; font-size: 12px; color: var(--muted); }
.opp-result strong { color: var(--text); }
.lock-msg { margin-top: 8px; padding: 8px 10px; border-radius: 8px; font-size: 12px; background: rgba(255,255,255,0.03); color: var(--muted); font-style: italic; }
.cancel-msg { margin-top: 8px; padding: 8px 10px; border-radius: 8px; font-size: 12px; background: rgba(255,107,107,0.06); color: var(--red); }
.result-section { margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
.result-label { font-size: 11px; color: var(--muted); margin-bottom: 7px; }
.result-row { display: flex; gap: 6px; }
.result-btn { flex: 1; background: var(--surface2); border: 1px solid var(--border2); border-radius: 10px; padding: 9px 10px; cursor: pointer; text-align: center; font-size: 13px; font-weight: 600; color: var(--muted); font-family: 'DM Sans', sans-serif; -webkit-tap-highlight-color: transparent; }
.result-btn.win-active { background: rgba(74,222,128,0.15); border-color: rgba(74,222,128,0.5); color: var(--green); }
.result-btn.lose-active { background: rgba(255,107,107,0.15); border-color: rgba(255,107,107,0.5); color: var(--red); }
.method-row { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }
.method-btn { font-size: 11px; font-weight: 500; padding: 5px 12px; border-radius: 999px; border: 1px solid var(--border2); background: var(--surface2); color: var(--muted); cursor: pointer; font-family: 'DM Sans', sans-serif; -webkit-tap-highlight-color: transparent; }
.method-btn.method-active { border-color: rgba(79,163,255,0.45); background: var(--blue-dim); color: var(--blue); }
.result-summary { display: flex; align-items: center; gap: 8px; margin-top: 9px; padding: 8px 12px; border-radius: 8px; font-size: 13px; font-weight: 600; }
.result-summary.win-summary { background: rgba(74,222,128,0.1); color: var(--green); border: 1px solid rgba(74,222,128,0.2); }
.result-summary.lose-summary { background: rgba(255,107,107,0.1); color: var(--red); border: 1px solid rgba(255,107,107,0.2); }
.result-clear { font-size: 11px; font-weight: 400; color: var(--muted); cursor: pointer; margin-left: auto; text-decoration: underline; }
.empty { text-align: center; padding: 40px 16px; color: var(--muted); font-size: 14px; }
</style>
</head>
<body>
<div class="page">
  <header>
    <div class="header-top">
      <div class="event-name">MARIANAS<br><span>PRO</span> MANILA<br><span style="font-size:30px;letter-spacing:2px;">2026</span></div>
      <div class="event-date">APR 26, 2026<br>MANILA, PH</div>
    </div>
    <div class="team-badge">Kamphuis Fabricio</div>
    <div class="sync-row">
      <div class="sync-dot" id="sync-dot"></div>
      <span id="sync-label">Connecting...</span>
    </div>
  </header>
  <div class="next-wrap">
    <div class="next-card">
      <div class="next-eyebrow">&#9654; Next match</div>
      <div class="next-name" id="nc-name">Loading...</div>
      <div class="next-sub" id="nc-sub"></div>
      <div class="countdown-row" id="nc-countdown">
        <div class="cd-unit"><div class="cd-num" id="cd-h">--</div><div class="cd-label">hrs</div></div>
        <div class="cd-unit"><div class="cd-num" id="cd-m">--</div><div class="cd-label">min</div></div>
        <div class="cd-unit"><div class="cd-num" id="cd-s">--</div><div class="cd-label">sec</div></div>
      </div>
      <div class="ready-banner" id="ready-banner">
        <div class="pulse"></div>
        <span id="ready-text">Head to the mat now!</span>
      </div>
    </div>
  </div>
  <div class="filters" id="filters"></div>
  <div id="cards"></div>
</div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getDatabase, ref, set, onValue } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

/* ── Firebase init ── */
var fbApp = initializeApp({
  apiKey: "AIzaSyDfQqyVSgfMUxhB3YdDHZ9zh0xu5EXRxtA",
  authDomain: "marianas-pro-ghjj.firebaseapp.com",
  databaseURL: "https://marianas-pro-ghjj-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId: "marianas-pro-ghjj",
  storageBucket: "marianas-pro-ghjj.firebasestorage.app",
  messagingSenderId: "362534730087",
  appId: "1:362534730087:web:8ca170a3136deaec33d7c2"
});
var db = getDatabase(fbApp);

/* ── Data ── */
var DATE = '2026-04-26';
var BELT_COLORS = { White:'#d1d5db', Yellow:'#facc15', Orange:'#fb923c', Green:'#4ade80', Blue:'#60a5fa', Purple:'#c084fc', Brown:'#a16207', Black:'#374151' };

var matches = [
  { id:0,  fighter:'Mikel',   type:'No-Gi', div:'Kid 5', belt:'White',  weight:'Middle',        maxW:'55.3', stage:'Final',        fight:'8',  mat:'5', start:'9:30',  ready:'8:50',  dur:'4 mins', opp:['-'],                               teams:['-'],                                     condFight:null },
  { id:1,  fighter:'Inigo',   type:'No-Gi', div:'Kid 6', belt:'White',  weight:'Light Feather', maxW:'49.9', stage:'Final',        fight:'16', mat:'3', start:'10:40', ready:'10:00', dur:'4 mins', opp:['Ebayan Lucas'],                    teams:['Clube De Jiujitsu'],                      condFight:null },
  { id:2,  fighter:'Odinn',   type:'Gi',    div:'Kid 2', belt:'White',  weight:'Light',         maxW:'31.8', stage:'Final',        fight:'36', mat:'2', start:'12:44', ready:'12:04', dur:'2 mins', opp:['Sumile Zion'],                     teams:['Deftac Six Blades'],                     condFight:null },
  { id:3,  fighter:'Bella',   type:'Gi',    div:'Kid 3', belt:'White',  weight:'Feather',       maxW:'31.8', stage:'Semifinal',    fight:'40', mat:'2', start:'12:57', ready:'12:17', dur:'3 mins', opp:['Custodio Mary'],                   teams:['Kamphuis Fabricio'],                     condFight:null },
  { id:4,  fighter:'Bella',   type:'Gi',    div:'Kid 3', belt:'White',  weight:'Feather',       maxW:'31.8', stage:'Final',        fight:'43', mat:'2', start:'13:08', ready:'12:28', dur:'3 mins', opp:['Leyte Sabrielle','Simbol Kendall'], teams:['Kamphuis Fabricio','Deftac Six Blades'], condFight:'40' },
  { id:5,  fighter:'Mikel',   type:'Gi',    div:'Kid 5', belt:'White',  weight:'Middle',        maxW:'56.7', stage:'Semifinal',    fight:'65', mat:'4', start:'14:56', ready:'14:16', dur:'4 mins', opp:['Eugerio Mikhail'],                 teams:['Deftac Six Blades'],                     condFight:null },
  { id:6,  fighter:'Mikel',   type:'Gi',    div:'Kid 5', belt:'White',  weight:'Middle',        maxW:'56.7', stage:'Final',        fight:'73', mat:'4', start:'15:33', ready:'14:53', dur:'4 mins', opp:['Reyes Fhilkevin'],                 teams:['Carpe Diem'],                            condFight:'65' },
  { id:7,  fighter:'Zion',    type:'Gi',    div:'Kid 6', belt:'Green',  weight:'Light Feather', maxW:'51.3', stage:'Quarterfinal', fight:'74', mat:'1', start:'15:39', ready:'14:59', dur:'4 mins', opp:['Matta Matteo'],                    teams:['Emerge Jiujitsu'],                       condFight:null },
  { id:8,  fighter:'Zion',    type:'Gi',    div:'Kid 6', belt:'Green',  weight:'Light Feather', maxW:'51.3', stage:'Semifinal',    fight:'77', mat:'1', start:'15:54', ready:'15:14', dur:'4 mins', opp:['De Guzman Ethan'],                 teams:['Kamphuis Fabricio'],                     condFight:'74' },
  { id:9,  fighter:'Martina', type:'Gi',    div:'Kid 6', belt:'Yellow', weight:'Light Feather', maxW:'51.3', stage:'Final',        fight:'79', mat:'1', start:'16:04', ready:'15:24', dur:'4 mins', opp:['Dumacian Tinker Bell'],            teams:['Deftac Six Blades'],                     condFight:null },
  { id:10, fighter:'Zion',    type:'Gi',    div:'Kid 6', belt:'Green',  weight:'Light Feather', maxW:'51.3', stage:'Final',        fight:'80', mat:'1', start:'16:09', ready:'15:29', dur:'4 mins', opp:['Siu Blake','Chang Eavan'],         teams:['Kamphuis Fabricio','Carpe Diem'],        condFight:'77' },
  { id:11, fighter:'Inigo',   type:'Gi',    div:'Kid 6', belt:'White',  weight:'Light Feather', maxW:'51.3', stage:'Semifinal',    fight:'81', mat:'3', start:'16:12', ready:'15:32', dur:'4 mins', opp:['Ebayan Lucas'],                    teams:['Clube De Jiujitsu'],                     condFight:null },
  { id:12, fighter:'Inigo',   type:'Gi',    div:'Kid 6', belt:'White',  weight:'Light Feather', maxW:'51.3', stage:'Final',        fight:'85', mat:'3', start:'16:32', ready:'15:52', dur:'4 mins', opp:['Montenegro Diego','Decena Joaquin'],teams:['Deftac Six Blades','Alliance Jiujitsu'], condFight:'81' }
];

var fightToId = {};
for (var i = 0; i < matches.length; i++) fightToId[matches[i].fight] = matches[i].id;

var selOpp    = {};
var results   = {};
var curFilter = 'all';

/* ── Helpers ── */
function mTime(m, useReady) {
  var t = useReady ? m.ready : m.start;
  var p = t.split(':');
  var h = parseInt(p[0], 10), mn = parseInt(p[1], 10);
  return new Date(DATE + 'T' + (h < 10 ? '0' : '') + h + ':' + (mn < 10 ? '0' : '') + mn + ':00');
}
function p2(n) { return n < 10 ? '0' + n : '' + n; }
function fmtCd(ms) {
  if (ms <= 0) return null;
  var t = Math.floor(ms / 1000);
  return { h: Math.floor(t / 3600), m: Math.floor((t % 3600) / 60), s: t % 60 };
}
function stCls(s) {
  if (s === 'Quarterfinal') return 'tag-quarter';
  if (s.indexOf('Semifinal') >= 0) return 'tag-semi';
  if (s.indexOf('Final') >= 0) return 'tag-final';
  return 'tag-cond';
}
function matchStatus(m) {
  if (!m.condFight) return 'active';
  var pid = fightToId[m.condFight];
  if (pid === undefined) return 'active';
  var pr = results[pid];
  if (!pr || !pr.outcome) return 'locked';
  return pr.outcome === 'win' ? 'active' : 'cancelled';
}
function nextIdx() {
  var now = new Date();
  for (var i = 0; i < matches.length; i++) {
    if (matchStatus(matches[i]) === 'active' && mTime(matches[i]) > now) return i;
  }
  return -1;
}

/* ── Firebase write helpers ── */
function fbSetResult(id, val) { set(ref(db, 'results/' + id), val || null); }
function fbSetOpp(id, idx)    { set(ref(db, 'selOpp/' + id), idx); }

/* ── Actions (attached to window so onclick can reach them) ── */
window.doSetFilter = function(key) {
  curFilter = key;
  var pills = document.querySelectorAll('.pill');
  for (var i = 0; i < pills.length; i++) {
    pills[i].classList.toggle('active', pills[i].getAttribute('data-k') === key);
  }
  render();
};
window.doSelOpp = function(id, idx) {
  selOpp[id] = idx;
  fbSetOpp(id, idx);
  render();
};
window.doSetOutcome = function(id, outcome) {
  var cur = results[id] ? results[id].outcome : null;
  if (cur === outcome) {
    results[id] = null;
    fbSetResult(id, null);
  } else {
    results[id] = { outcome: outcome };
    fbSetResult(id, { outcome: outcome });
  }
  render();
};
window.doSetMethod = function(id, method) {
  if (!results[id] || !results[id].outcome) return;
  var updated = results[id].method === method
    ? { outcome: results[id].outcome }
    : { outcome: results[id].outcome, method: method };
  results[id] = updated;
  fbSetResult(id, updated);
  render();
};
window.doClearRes = function(id) {
  delete results[id];
  fbSetResult(id, null);
  render();
};

/* ── Build filter pills ── */
function buildFilters() {
  var seen = {}, fighters = [];
  for (var i = 0; i < matches.length; i++) {
    if (!seen[matches[i].fighter]) { seen[matches[i].fighter] = 1; fighters.push(matches[i].fighter); }
  }
  var h = '<button class="pill active" data-k="all" onclick="doSetFilter(\'all\')">All</button>';
  for (var j = 0; j < fighters.length; j++) {
    h += '<button class="pill" data-k="' + fighters[j] + '" onclick="doSetFilter(\'' + fighters[j] + '\')">' + fighters[j] + '</button>';
  }
  h += '<button class="pill" data-k="Gi" onclick="doSetFilter(\'Gi\')">Gi</button>';
  h += '<button class="pill" data-k="No-Gi" onclick="doSetFilter(\'No-Gi\')">No-Gi</button>';
  document.getElementById('filters').innerHTML = h;
}

/* ── Next match banner ── */
function updateNext() {
  var ni = nextIdx(), now = new Date();
  if (ni === -1) {
    document.getElementById('nc-name').textContent = 'All matches complete!';
    document.getElementById('nc-sub').textContent = 'Great job team!';
    document.getElementById('nc-countdown').innerHTML = '<div class="all-done">Done for the day!</div>';
    document.getElementById('ready-banner').classList.remove('show');
    return;
  }
  var m = matches[ni];
  var diff = mTime(m) - now, rdiff = mTime(m, true) - now;
  var cd = fmtCd(diff);
  document.getElementById('nc-name').textContent = m.fighter + ' \u2014 ' + m.stage;
  document.getElementById('nc-sub').textContent = m.type + ' \u00b7 ' + m.div + ' \u00b7 Mat ' + m.mat + ' \u00b7 Fight #' + m.fight;
  if (cd) {
    document.getElementById('cd-h').textContent = p2(cd.h);
    document.getElementById('cd-m').textContent = p2(cd.m);
    document.getElementById('cd-s').textContent = p2(cd.s);
  }
  var banner = document.getElementById('ready-banner');
  if (rdiff <= 0 && diff > 0) {
    banner.classList.add('show');
    document.getElementById('ready-text').textContent = m.fighter + ' \u2014 head to Mat ' + m.mat + ' now!';
  } else if (rdiff > 0 && rdiff <= 900000) {
    banner.classList.add('show');
    var rcd = fmtCd(rdiff);
    document.getElementById('ready-text').textContent = 'Ready in ' + rcd.m + 'm ' + rcd.s + 's \u2014 Mat ' + m.mat;
  } else {
    banner.classList.remove('show');
  }
}

/* ── Main render ── */
function render() {
  var now = new Date(), ni = nextIdx(), html = '';
  var list = [];
  for (var i = 0; i < matches.length; i++) {
    var m = matches[i];
    if (curFilter === 'all' || m.fighter === curFilter || m.type === curFilter) list.push(m);
  }
  if (!list.length) { document.getElementById('cards').innerHTML = '<div class="empty">No matches found</div>'; return; }

  for (var li = 0; li < list.length; li++) {
    var m = list[li];
    var status = matchStatus(m);
    var mt = mTime(m);
    var past = (status === 'active') && (mt < now);
    var isNext = false;
    for (var j = 0; j < matches.length; j++) { if (matches[j] === m && j === ni) { isNext = true; break; } }
    var diff = mt - now, cd = fmtCd(diff);
    var si = (selOpp[m.id] !== undefined) ? selOpp[m.id] : -1;
    var bc = BELT_COLORS[m.belt] || '#ccc';
    var res = results[m.id] || null;
    var hasRes = res && res.outcome;

    /* card class */
    var cls = 'card';
    if (status === 'locked')         cls += ' locked';
    else if (status === 'cancelled') cls += ' cancelled';
    else if (isNext)                 cls += ' is-next';
    else if (past && !hasRes)        cls += ' is-past';
    if (hasRes && res.outcome === 'win')  cls += ' has-win';
    if (hasRes && res.outcome === 'lose') cls += ' has-lose';

    /* countdown text */
    var cdTxt = '';
    if (status === 'active') {
      if (past) cdTxt = '<div class="match-cd">Completed</div>';
      else if (cd) {
        var soon = (cd.h === 0 && cd.m < 30);
        cdTxt = '<div class="match-cd' + (soon ? ' soon' : '') + '">' + (cd.h > 0 ? cd.h + 'h ' : '') + cd.m + 'm away</div>';
      }
    }

    /* badge */
    var badge = isNext ? '<span class="next-badge">NEXT</span>'
      : status === 'locked' ? '<span class="locked-badge">WAITING</span>'
      : status === 'cancelled' ? '<span class="cancelled-badge">CANCELLED</span>' : '';

    /* cond tag */
    var condTag = m.condFight ? '<span class="tag tag-cond">If win #' + m.condFight + '</span>' : '';

    /* vs section */
    var vs = '';
    if (status === 'cancelled') {
      vs = '<div class="cancel-msg">Cancelled \u2014 fight #' + m.condFight + ' was not won.</div>';
    } else if (status === 'locked') {
      vs = '<div class="lock-msg">Waiting for result of fight #' + m.condFight + '...</div>';
    } else if (m.opp[0] === '-') {
      vs = '<div class="vs-row">No opponent listed yet</div>';
    } else if (m.opp.length > 1) {
      var btns = '';
      for (var oi = 0; oi < m.opp.length; oi++) {
        btns += '<button class="opp-btn' + (si === oi ? ' selected' : '') + '" onclick="doSelOpp(' + m.id + ',' + oi + ')">';
        btns += '<div class="opp-btn-name">' + m.opp[oi] + '</div>';
        btns += '<div class="opp-btn-team">' + m.teams[oi] + '</div></button>';
      }
      var orTxt = si >= 0
        ? '<div class="opp-result">vs <strong>' + m.opp[si] + '</strong> &middot; ' + m.teams[si] + '</div>'
        : '<div class="opp-result" style="color:var(--muted);font-style:italic">Select opponent above</div>';
      vs = '<div><div class="opp-label">Choose final opponent &darr;</div><div class="opp-btns">' + btns + '</div>' + orTxt + '</div>';
    } else {
      vs = '<div class="vs-row">vs <strong>' + m.opp[0] + '</strong> &middot; ' + m.teams[0] + '</div>';
    }

    /* result section */
    var rs = '';
    if (status === 'active' && past) {
      var meths = ['Points', 'Submission', 'Disqualification'];
      if (!hasRes) {
        rs  = '<div class="result-section"><div class="result-label">Record result &darr;</div><div class="result-row">';
        rs += '<button class="result-btn" onclick="doSetOutcome(' + m.id + ',\'win\')">Win</button>';
        rs += '<button class="result-btn" onclick="doSetOutcome(' + m.id + ',\'lose\')">Loss</button>';
        rs += '</div></div>';
      } else {
        var mb = '';
        for (var mi = 0; mi < meths.length; mi++) {
          var mk = meths[mi].toLowerCase();
          mb += '<button class="method-btn' + (res.method === mk ? ' method-active' : '') + '" onclick="doSetMethod(' + m.id + ',\'' + mk + '\')">' + meths[mi] + '</button>';
        }
        var emoji = res.outcome === 'win' ? '&#127942;' : '&#128170;';
        var lbl   = res.outcome === 'win' ? 'WIN' : 'LOSS';
        var mlbl  = res.method ? ' by ' + res.method : '';
        var sc    = res.outcome === 'win' ? 'win-summary' : 'lose-summary';
        rs  = '<div class="result-section"><div class="result-row">';
        rs += '<button class="result-btn' + (res.outcome === 'win'  ? ' win-active'  : '') + '" onclick="doSetOutcome(' + m.id + ',\'win\')">Win</button>';
        rs += '<button class="result-btn' + (res.outcome === 'lose' ? ' lose-active' : '') + '" onclick="doSetOutcome(' + m.id + ',\'lose\')">Loss</button>';
        rs += '</div><div class="method-row">' + mb + '</div>';
        rs += '<div class="result-summary ' + sc + '"><span>' + emoji + ' ' + lbl + mlbl + '</span>';
        rs += '<span class="result-clear" onclick="doClearRes(' + m.id + ')">clear</span></div></div>';
      }
    }

    var readyRow = status === 'active' ? '<div class="ready-row">&#9200; Ready at <strong>' + m.ready + '</strong> &middot; Mat ' + m.mat + '</div>' : '';

    html += '<div class="' + cls + '">';
    html += '<div class="card-header"><div><div class="fighter-row">';
    html += '<div class="belt-pip" style="background:' + bc + '"></div>';
    html += '<div class="fighter-name">' + m.fighter + '</div>' + badge;
    html += '</div></div>';
    html += '<div class="time-col"><div class="start-time' + (past ? ' past' : '') + '">' + m.start + '</div>' + cdTxt + '</div>';
    html += '</div>';
    html += readyRow;
    html += '<div class="tags"><span class="tag ' + (m.type === 'Gi' ? 'tag-gi' : 'tag-nogi') + '">' + m.type + '</span>';
    html += '<span class="tag ' + stCls(m.stage) + '">' + m.stage + '</span>' + condTag + '</div>';
    html += '<div class="meta-grid">';
    html += '<div class="meta-item">Div <strong>' + m.div + '</strong></div>';
    html += '<div class="meta-item">Weight <strong>' + m.weight + '</strong></div>';
    html += '<div class="meta-item">Fight <strong>#' + m.fight + '</strong></div>';
    html += '<div class="meta-item">Duration <strong>' + m.dur + '</strong></div>';
    html += '<div class="meta-item">Max <strong>' + m.maxW + ' kg</strong></div>';
    html += '<div class="meta-item">Belt <strong>' + m.belt + '</strong></div>';
    html += '</div><div class="divider"></div>' + vs + rs + '</div>';
  }
  document.getElementById('cards').innerHTML = html;
}

/* ── Boot immediately (don't wait for Firebase) ── */
buildFilters();
updateNext();
render();
setInterval(function() { updateNext(); }, 1000);

/* ── Firebase listeners (update when data arrives) ── */
try {
  onValue(ref(db, 'results'), function(snapshot) {
    results = snapshot.val() || {};
    document.getElementById('sync-dot').classList.add('live');
    document.getElementById('sync-label').textContent = 'Live \u2014 synced';
    render();
  });

  onValue(ref(db, 'selOpp'), function(snapshot) {
    selOpp = snapshot.val() || {};
    render();
  });
} catch(e) {
  document.getElementById('sync-label').textContent = 'Offline mode';
}
</script>

</body>
</html>
